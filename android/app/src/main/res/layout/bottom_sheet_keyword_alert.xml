<?xml version="1.0" encoding="utf-8"?>
<!-- 키워드 알림 설정 iOS 스타일 다이얼로그 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_dialog_rounded"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="20dp">

    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_notification"
        android:tint="@color/md_theme_primary"
        android:contentDescription="알림" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="키워드 알림 설정"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_primary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="등록한 키워드가 포함된 게시글이 올라오면 알림을 받습니다."
        android:textSize="13sp"
        android:textColor="@color/app_text_tertiary"
        android:gravity="center" />

    <!-- 키워드 입력 + 추가 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp">

        <EditText
            android:id="@+id/et_keyword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:hint="키워드 입력 (예: 대구, 수영)"
            android:textSize="14sp"
            android:textColor="@color/app_text_secondary"
            android:textColorHint="@color/app_text_hint"
            android:paddingHorizontal="14dp"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:maxLines="1"
            android:importantForAutofill="no" />

        <TextView
            android:id="@+id/btn_add_keyword"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="추가"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_primary"
            android:background="?attr/selectableItemBackground"
            android:paddingHorizontal="14dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/app_divider"
        android:layout_marginTop="12dp" />

    <!-- 등록된 키워드 목록 헤더 -->
    <TextView
        android:id="@+id/tv_keyword_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="등록된 키워드"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_hint"
        android:paddingTop="12dp"
        android:paddingBottom="6dp" />

    <!-- 키워드 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_keywords"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="200dp"
        android:clipToPadding="false" />

    <!-- 빈 상태 -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="등록된 키워드가 없습니다.\n키워드를 추가하면 해당 단어가 포함된\n게시글이 올라올 때 알림을 받을 수 있습니다."
        android:textSize="13sp"
        android:textColor="@color/app_text_hint"
        android:gravity="center"
        android:paddingVertical="20dp"
        android:visibility="visible" />

    <!-- 닫기 버튼 -->
    <TextView
        android:id="@+id/btn_close"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="닫기"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_secondary"
        android:background="@drawable/bg_button_dialog_secondary" />

</LinearLayout>
