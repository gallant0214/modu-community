<?xml version="1.0" encoding="utf-8"?>
<!-- 키워드 알림 설정 BottomSheet -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/app_surface"
    android:paddingBottom="24dp">

    <!-- 핸들바 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_handle_bar" />

    <!-- 타이틀 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="키워드 알림 설정"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_primary"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="등록한 키워드가 포함된 게시글이 올라오면 알림을 받습니다."
        android:textSize="13sp"
        android:textColor="@color/app_text_hint"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp" />

    <!-- 키워드 입력 + 추가 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/et_keyword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:hint="키워드 입력 (예: 대구, 수영)"
            android:textSize="14sp"
            android:textColor="@color/app_text_secondary"
            android:textColorHint="@color/app_text_hint"
            android:paddingHorizontal="14dp"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:maxLines="1"
            android:importantForAutofill="no" />

        <TextView
            android:id="@+id/btn_add_keyword"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="추가"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_primary"
            android:background="?attr/selectableItemBackground"
            android:paddingHorizontal="14dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/app_divider" />

    <!-- 등록된 키워드 목록 헤더 -->
    <TextView
        android:id="@+id/tv_keyword_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="등록된 키워드"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_hint"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp" />

    <!-- 키워드 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_keywords"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="300dp"
        android:clipToPadding="false" />

    <!-- 빈 상태 -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="등록된 키워드가 없습니다.\n키워드를 추가하면 해당 단어가 포함된\n게시글이 올라올 때 알림을 받을 수 있습니다."
        android:textSize="13sp"
        android:textColor="@color/app_text_hint"
        android:gravity="center"
        android:paddingVertical="24dp"
        android:visibility="visible" />

</LinearLayout>
