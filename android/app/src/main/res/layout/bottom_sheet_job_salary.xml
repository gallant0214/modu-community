<?xml version="1.0" encoding="utf-8"?>
<!-- 급여 선택 바텀시트 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="16dp">

    <!-- 핸들 바 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_handle_bar" />

    <!-- 타이틀 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="급여 선택"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_primary"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- 급여 유형 라디오 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="급여 유형"
                android:textSize="13sp"
                android:textColor="@color/app_text_tertiary" />

            <RadioGroup
                android:id="@+id/rg_salary_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <RadioButton android:id="@+id/rb_hourly" android:layout_width="match_parent" android:layout_height="40dp" android:text="시급" android:textSize="15sp" android:textColor="@color/app_text_secondary" />
                <RadioButton android:id="@+id/rb_monthly" android:layout_width="match_parent" android:layout_height="40dp" android:text="월급" android:textSize="15sp" android:textColor="@color/app_text_secondary" />
                <RadioButton android:id="@+id/rb_per_case" android:layout_width="match_parent" android:layout_height="40dp" android:text="건당" android:textSize="15sp" android:textColor="@color/app_text_secondary" />
                <RadioButton android:id="@+id/rb_negotiable" android:layout_width="match_parent" android:layout_height="40dp" android:text="협의" android:textSize="15sp" android:textColor="@color/app_text_secondary" />
            </RadioGroup>

            <!-- 금액 입력 (협의 시 숨김) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="금액 (원)"
                android:visibility="gone"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:inputType="number"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 추가 체크박스 -->
            <CheckBox
                android:id="@+id/cb_incentive"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="인센티브 있음"
                android:textSize="14sp"
                android:textColor="@color/app_text_secondary"
                android:layout_marginTop="8dp" />

            <CheckBox
                android:id="@+id/cb_daily_weekly"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="주급/당일지급 가능"
                android:textSize="14sp"
                android:textColor="@color/app_text_secondary" />
        </LinearLayout>
    </ScrollView>

    <!-- 버튼 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="취소"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.TextButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="완료"
            android:textSize="14sp"
            android:layout_marginStart="8dp"
            style="@style/Widget.Material3.Button.TonalButton" />
    </LinearLayout>
</LinearLayout>
