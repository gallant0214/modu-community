<?xml version="1.0" encoding="utf-8"?>
<!-- 게시글 작성 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_surface"
    tools:context="com.moduji.app.ui.community.PostWriteFragment">

    <!-- 상단 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="뒤로가기"
            app:tint="@color/app_icon_dark" />

        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="글쓰기"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_primary" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/app_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 작성자 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="작성자 (필수)"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary" />

            <EditText
                android:id="@+id/et_author"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:hint="닉네임"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <!-- 비밀번호 (비로그인 시에만 표시) -->
            <LinearLayout
                android:id="@+id/layout_password"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="비밀번호 (필수)"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_text_tertiary"
                    android:layout_marginTop="16dp" />

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_search_bar"
                    android:hint="수정/삭제 시 필요"
                    android:textSize="14sp"
                    android:textColor="@color/app_text_secondary"
                    android:textColorHint="@color/app_text_hint"
                    android:paddingHorizontal="12dp"
                    android:inputType="textPassword"
                    android:maxLines="1"
                    android:importantForAutofill="no" />
            </LinearLayout>

            <!-- 지역 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="지역 (필수)"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/et_region"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:hint="예: 서울, 경기"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <!-- 태그 (드롭다운) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="태그 (필수)"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/tv_tag_select"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:hint="태그를 선택하세요"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="12dp"
                android:gravity="center_vertical"
                android:drawableEnd="@drawable/ic_expand_more"
                android:drawableTint="@color/app_icon_tint_muted" />

            <!-- 제목 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="제목 (필수)"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:hint="제목을 입력하세요"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <!-- 내용 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="내용 (필수)"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/et_content"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:hint="내용을 입력하세요"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:padding="12dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:importantForAutofill="no" />

            <!-- 등록 버튼 -->
            <TextView
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="등록"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/md_theme_onPrimary"
                android:background="@drawable/bg_login_button" />

            <!-- 로딩 -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
