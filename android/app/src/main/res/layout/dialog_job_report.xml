<?xml version="1.0" encoding="utf-8"?>
<!-- 구인 게시글 신고 다이얼로그 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="16dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_handle_bar" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="신고 사유 선택"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_primary"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp" />

    <RadioGroup
        android:id="@+id/rg_report_reason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp">

        <RadioButton
            android:id="@+id/rb_fake_info"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="허위 또는 과장된 구인 정보"
            android:textSize="15sp"
            android:textColor="@color/app_text_secondary" />

        <RadioButton
            android:id="@+id/rb_no_intent"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="실제 채용 의사 없음"
            android:textSize="15sp"
            android:textColor="@color/app_text_secondary" />

        <RadioButton
            android:id="@+id/rb_contact_issue"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="연락처 문제"
            android:textSize="15sp"
            android:textColor="@color/app_text_secondary" />

        <RadioButton
            android:id="@+id/rb_illegal"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="불법/부적절한 내용"
            android:textSize="15sp"
            android:textColor="@color/app_text_secondary" />

        <RadioButton
            android:id="@+id/rb_duplicate"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="반복 게시"
            android:textSize="15sp"
            android:textColor="@color/app_text_secondary" />

        <RadioButton
            android:id="@+id/rb_other"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="기타 (직접 입력)"
            android:textSize="15sp"
            android:textColor="@color/app_text_secondary" />
    </RadioGroup>

    <!-- 기타 직접 입력 필드 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_other_reason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="4dp"
        android:hint="신고 사유를 입력하세요"
        android:visibility="gone"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_other_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:gravity="top" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_submit_report"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:text="신고하기"
        android:textSize="14sp"
        app:cornerRadius="8dp" />
</LinearLayout>
