<?xml version="1.0" encoding="utf-8"?>
<!-- 게시글 상세 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_surface"
    tools:context="com.moduji.app.ui.community.PostDetailFragment">

    <!-- 상단 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="뒤로가기"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/app_icon_dark" />

        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="게시글"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_primary"
            android:singleLine="true"
            android:ellipsize="end" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/app_divider" />

    <!-- 스크롤 본문 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 로딩 -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="40dp"
                android:visibility="gone" />

            <!-- 게시글 본문 영역 -->
            <LinearLayout
                android:id="@+id/layout_post"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- 태그 칩 + 더보기(수정/삭제) -->
                <LinearLayout
                    android:id="@+id/layout_tags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp">

                    <TextView
                        android:id="@+id/tv_tag_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/md_theme_primary"
                        android:background="@drawable/bg_category_chip"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_region_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/app_text_tertiary"
                        android:background="@drawable/bg_tag_region"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginStart="6dp"
                        android:visibility="gone" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <ImageView
                        android:id="@+id/btn_bookmark"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_bookmark"
                        android:contentDescription="북마크"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/app_icon_tint"
                        android:scaleType="centerInside"
                        android:padding="2dp"
                        android:layout_marginEnd="8dp" />

                    <ImageView
                        android:id="@+id/btn_more"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_more_vert"
                        android:contentDescription="더보기"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/app_icon_tint"
                        android:padding="2dp" />
                </LinearLayout>

                <!-- 제목 -->
                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_text_primary"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="4dp" />

                <!-- 메타: 작성자 · 지역 · 날짜    조회수  ··· -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tv_meta"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="@color/app_text_tertiary"
                        android:singleLine="true"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tv_views"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/app_text_hint"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- 본문 (인용 스타일 박스) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/bg_search_bar"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_content"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="@color/app_text_secondary"
                        android:lineSpacingExtra="6dp" />
                </LinearLayout>

                <!-- 구분선 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/app_divider"
                    android:layout_marginTop="20dp" />

                <!-- 액션 바: 신고 | 좋아요 N | 댓글달기 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:id="@+id/btn_report"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="신고"
                        android:drawableStart="@drawable/ic_report_outline"
                        android:drawablePadding="4dp"
                        android:textSize="13sp"
                        android:textColor="#E53E3E"
                        android:background="?attr/selectableItemBackground"
                        android:paddingVertical="4dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/btn_like"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="좋아요 0"
                        android:drawableStart="@drawable/ic_heart_outline"
                        android:drawablePadding="4dp"
                        android:textSize="13sp"
                        android:textColor="@color/app_text_secondary"
                        android:background="?attr/selectableItemBackground"
                        android:paddingVertical="4dp" />

                    <TextView
                        android:id="@+id/btn_write_comment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 구분선 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/app_divider" />
            </LinearLayout>

            <!-- 댓글 섹션 -->
            <LinearLayout
                android:id="@+id/layout_comments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- 전체 댓글 N개  ✓최신순  인기순  공감순 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <TextView
                        android:id="@+id/tv_comments_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_text_primary"
                        tools:text="전체 댓글 5개" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/btn_sort_latest"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓최신순"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_text_primary"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="4dp" />

                    <TextView
                        android:id="@+id/btn_sort_popular"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="인기순"
                        android:textSize="12sp"
                        android:textColor="@color/app_text_hint"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="4dp"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/btn_sort_likes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="공감순"
                        android:textSize="12sp"
                        android:textColor="@color/app_text_hint"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="4dp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_comments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 댓글 입력 바 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/app_divider" />

    <LinearLayout
        android:id="@+id/layout_comment_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="8dp"
        android:background="@color/app_surface">

        <EditText
            android:id="@+id/et_comment"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:hint="댓글을 입력하세요"
            android:textSize="13sp"
            android:textColor="@color/app_text_secondary"
            android:textColorHint="@color/app_text_hint"
            android:paddingHorizontal="12dp"
            android:inputType="text"
            android:imeOptions="actionSend"
            android:maxLines="1"
            android:importantForAutofill="no" />

        <TextView
            android:id="@+id/btn_submit_comment"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="등록"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onPrimary"
            android:background="@drawable/bg_login_button"
            android:paddingHorizontal="16dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
