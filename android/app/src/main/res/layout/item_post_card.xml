<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/app_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp">

        <!-- 상단: 종목 태그 + 지역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tv_post_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="축구"
                android:textSize="11sp"
                android:textColor="@color/app_tag_sport_text"
                android:background="@drawable/bg_tag"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />

            <TextView
                android:id="@+id/tv_post_region"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="서울"
                android:textSize="11sp"
                android:textColor="@color/app_text_hint"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- 제목 -->
        <TextView
            android:id="@+id/tv_post_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="실기 시험 후기 공유합니다"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_primary"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- 내용 미리보기 -->
        <TextView
            android:id="@+id/tv_post_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="시험장 분위기가 생각보다 편했고..."
            android:textSize="13sp"
            android:textColor="@color/app_text_job_meta"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="4dp" />

        <!-- 하단: 작성자 · 날짜 · 좋아요 · 댓글 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/tv_post_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="익명"
                android:textSize="11sp"
                android:textColor="@color/app_text_disabled" />

            <View
                android:layout_width="2dp"
                android:layout_height="2dp"
                android:layout_marginHorizontal="5dp"
                android:background="@color/app_icon_tint_arrow" />

            <TextView
                android:id="@+id/tv_post_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="03.01"
                android:textSize="11sp"
                android:textColor="@color/app_text_disabled" />

            <TextView
                android:id="@+id/tv_post_likes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="♥ 12"
                android:textSize="11sp"
                android:textColor="@color/app_text_disabled"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tv_post_comments"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 3"
                android:textSize="11sp"
                android:textColor="@color/app_text_disabled" />
        </LinearLayout>
    </LinearLayout>

    <!-- 구분선 (풀 너비) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/app_divider" />
</LinearLayout>
