<?xml version="1.0" encoding="utf-8"?>
<!-- 지역별 구인 게시글 리스트 화면 -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    tools:context="com.moduji.app.ui.jobs.JobsListFragment">

    <!-- 메인 콘텐츠 (헤더 + 검색 + 리스트 + 빈 상태) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 상단 헤더: 뒤로가기 + 지역명 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp">

            <!-- 뒤로가기 -->
            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="뒤로가기"
                android:scaleType="centerInside"
                android:padding="8dp" />

            <!-- 지역명 -->
            <TextView
                android:id="@+id/tv_region_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="구미시"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_primary"
                android:layout_marginStart="4dp" />

            <!-- 지역변경 버튼 -->
            <TextView
                android:id="@+id/btn_change_region"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="지역변경"
                android:textSize="12sp"
                android:textColor="@color/md_theme_primary"
                android:background="@drawable/bg_btn_region_change"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:layout_marginEnd="4dp" />

        </LinearLayout>

        <!-- 게시글 검색 바 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_bar">

            <!-- 검색 유형 선택 -->
            <LinearLayout
                android:id="@+id/btn_search_type"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="4dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:id="@+id/tv_search_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="제목"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_theme_primary" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="2dp"
                    android:src="@drawable/ic_expand_more"
                    android:contentDescription="검색 유형"
                    app:tint="@color/md_theme_primary" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="20dp"
                android:background="@color/app_divider"
                android:layout_marginHorizontal="4dp" />

            <!-- 검색 입력 -->
            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="게시글 검색"
                android:textSize="14sp"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="8dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- 종목 추천 리스트 (종목 검색 시 초성 매칭) -->
        <ListView
            android:id="@+id/lv_sport_suggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_search_bar"
            android:divider="@color/app_divider"
            android:dividerHeight="0.5dp"
            android:visibility="gone"
            android:maxHeight="200dp"
            android:nestedScrollingEnabled="false" />

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/app_divider" />

        <!-- 구인 게시글 리스트 -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_jobs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                tools:listitem="@layout/item_job" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- 빈 상태 -->
        <LinearLayout
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_empty_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="아직 구인 글이 없습니다."
                android:textSize="14sp"
                android:textColor="@color/app_text_hint" />

            <TextView
                android:id="@+id/tv_empty_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="첫 번째 구인 글을 작성해보세요!"
                android:textSize="13sp"
                android:textColor="@color/app_text_faint"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 글쓰기 FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_write"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="72dp"
        android:src="@drawable/ic_edit"
        android:contentDescription="구인 글 작성"
        app:backgroundTint="@color/md_theme_primary"
        app:tint="@color/md_theme_onPrimary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
