<?xml version="1.0" encoding="utf-8"?>
<!-- 구인 게시글 상세 화면 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg">

    <!-- 상단 헤더: 뒤로가기 + 타이틀 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp"
        android:background="@color/app_surface">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로가기"
            android:scaleType="centerInside"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="구인 상세"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_primary"
            android:layout_marginStart="4dp" />

        <TextView
            android:id="@+id/btn_report"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="⚠️ 신고"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/app_badge_new_text"
            android:paddingHorizontal="10dp"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/app_divider" />

    <!-- 스크롤 영역 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 메인 정보 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/app_surface"
                android:paddingHorizontal="16dp"
                android:paddingVertical="20dp">

                <!-- 태그: 고용형태 + 종목 + 지역 + 더보기 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tv_employment_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/md_theme_primary"
                        android:background="@drawable/bg_chip_employment"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp" />

                    <TextView
                        android:id="@+id/tv_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/app_tag_sport_text"
                        android:background="@drawable/bg_tag"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:layout_marginStart="6dp" />

                    <TextView
                        android:id="@+id/tv_region"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/app_text_hint"
                        android:layout_marginStart="8dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <TextView
                        android:id="@+id/tv_bookmark_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/app_text_hint"
                        android:layout_marginEnd="2dp" />

                    <ImageView
                        android:id="@+id/btn_bookmark"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_bookmark"
                        android:contentDescription="북마크"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/app_icon_tint"
                        android:scaleType="centerInside"
                        android:padding="2dp"
                        android:layout_marginEnd="8dp" />

                    <ImageView
                        android:id="@+id/btn_more"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_more_vert"
                        android:contentDescription="더보기"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/app_icon_tint"
                        android:padding="2dp" />
                </LinearLayout>

                <!-- 제목 -->
                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_text_primary"
                    android:lineSpacingExtra="2dp" />

                <!-- 센터명 -->
                <TextView
                    android:id="@+id/tv_center_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/app_text_tertiary"
                    android:layout_marginTop="8dp" />

                <!-- 메타: 등록일 · 조회수 -->
                <TextView
                    android:id="@+id/tv_meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/app_text_hint"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- 업체 주소 -->
            <LinearLayout
                android:id="@+id/layout_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/app_surface"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="업체 주소"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_text_secondary" />

                <TextView
                    android:id="@+id/tv_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/app_text_primary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- 작성자 정보 + 연락처 (한 행) -->
            <LinearLayout
                android:id="@+id/layout_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/app_surface"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <!-- 작성자 정보 (왼쪽) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="작성자 정보"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_text_secondary" />

                    <TextView
                        android:id="@+id/tv_author_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/app_text_primary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- 연락처 (오른쪽) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_contact_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="연락처"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_text_secondary" />

                    <TextView
                        android:id="@+id/tv_contact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/app_text_primary"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 구분 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/app_bg" />

            <!-- 급여 정보 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/app_surface"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="급여"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_text_secondary" />

                <TextView
                    android:id="@+id/tv_salary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_salary_text"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/app_divider" />

            <!-- 모집 인원 -->
            <LinearLayout
                android:id="@+id/layout_headcount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/app_surface"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/app_divider"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="모집 인원"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_text_secondary" />

                <TextView
                    android:id="@+id/tv_headcount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/app_text_primary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- 모집기간 -->
            <LinearLayout
                android:id="@+id/layout_deadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/app_surface"
                android:paddingHorizontal="16dp"
                android:paddingVertical="16dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/app_divider"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="모집기간"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_text_secondary" />

                <TextView
                    android:id="@+id/tv_deadline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/app_text_primary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- 구분 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/app_bg" />

            <!-- 상세 내용 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/app_surface"
                android:paddingHorizontal="16dp"
                android:paddingVertical="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="상세 내용"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/app_text_primary"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

            <!-- 우대조건 -->
            <LinearLayout
                android:id="@+id/layout_preferences"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/app_surface"
                android:paddingHorizontal="16dp"
                android:paddingBottom="16dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/app_divider"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="우대조건"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_text_secondary" />

                <TextView
                    android:id="@+id/tv_preferences"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/app_text_primary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- 복리후생 -->
            <LinearLayout
                android:id="@+id/layout_benefits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/app_surface"
                android:paddingHorizontal="16dp"
                android:paddingBottom="20dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/app_divider"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="복리후생"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_text_secondary" />

                <TextView
                    android:id="@+id/tv_benefits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="@color/app_text_primary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- 하단 여백 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
