<?xml version="1.0" encoding="utf-8"?>
<!-- 구인 게시글 리스트 아이템 -->
<!-- 고용형태 Chip + 종목 태그 + 제목 + 센터명 + 급여 + 등록일/조회수 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/app_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp">

        <!-- 상단: 고용형태 Chip + 종목 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <!-- 고용형태 -->
            <TextView
                android:id="@+id/tv_employment_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="정규직"
                android:textSize="11sp"
                android:textColor="@color/md_theme_primary"
                android:background="@drawable/bg_chip_employment"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />

            <!-- 종목 태그 (중립 톤) -->
            <TextView
                android:id="@+id/tv_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="수영"
                android:textSize="11sp"
                android:textColor="@color/app_tag_sport_text"
                android:background="@drawable/bg_tag"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginStart="6dp" />

            <!-- 스페이서 -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 모집 상태 뱃지 -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[모집중]"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/app_salary_text" />
        </LinearLayout>

        <!-- 제목 -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OO스포츠센터 수영 지도사 모집"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_primary"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- 센터명 -->
        <TextView
            android:id="@+id/tv_center_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OO스포츠센터"
            android:textSize="13sp"
            android:textColor="@color/app_text_tertiary"
            android:layout_marginTop="4dp" />

        <!-- 모집기간 (있으면 표시) -->
        <TextView
            android:id="@+id/tv_deadline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/app_text_job_meta"
            android:layout_marginTop="2dp"
            android:visibility="gone" />

        <!-- 급여 + 등록일/조회수 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <!-- 급여 (녹색 강조) -->
            <TextView
                android:id="@+id/tv_salary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="월 250~300만원"
                android:textSize="14sp"
                android:textColor="@color/app_salary_text"
                android:textStyle="bold" />

            <!-- 등록일 -->
            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘"
                android:textSize="11sp"
                android:textColor="@color/app_text_hint" />

            <View
                android:layout_width="2dp"
                android:layout_height="2dp"
                android:layout_marginHorizontal="5dp"
                android:background="@color/app_icon_tint_arrow" />

            <!-- 조회수 -->
            <TextView
                android:id="@+id/tv_views"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="조회 120"
                android:textSize="11sp"
                android:textColor="@color/app_text_hint" />
        </LinearLayout>
    </LinearLayout>

    <!-- 구분선 (풀 너비) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/app_divider" />
</LinearLayout>
