<?xml version="1.0" encoding="utf-8"?>
<!-- 모집 인원 선택 바텀시트 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="16dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_handle_bar" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="모집 인원"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_primary"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp" />

    <RadioGroup
        android:id="@+id/rg_headcount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp">

        <RadioButton android:id="@+id/rb_one" android:layout_width="match_parent" android:layout_height="44dp" android:text="1명" android:textSize="15sp" android:textColor="@color/app_text_secondary" />
        <RadioButton android:id="@+id/rb_two_three" android:layout_width="match_parent" android:layout_height="44dp" android:text="2~3명" android:textSize="15sp" android:textColor="@color/app_text_secondary" />
        <RadioButton android:id="@+id/rb_four_plus" android:layout_width="match_parent" android:layout_height="44dp" android:text="4명 이상" android:textSize="15sp" android:textColor="@color/app_text_secondary" />
        <RadioButton android:id="@+id/rb_custom" android:layout_width="match_parent" android:layout_height="44dp" android:text="직접 입력" android:textSize="15sp" android:textColor="@color/app_text_secondary" />
    </RadioGroup>

    <!-- 직접 입력 필드 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_custom_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="4dp"
        android:hint="인원 수"
        android:visibility="gone"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_custom_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:inputType="number"
            android:maxLines="1" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_confirm"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:text="확인"
        android:textSize="14sp"
        android:visibility="gone"
        style="@style/Widget.Material3.Button.TonalButton" />
</LinearLayout>
