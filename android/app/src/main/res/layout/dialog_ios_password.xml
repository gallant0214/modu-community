<?xml version="1.0" encoding="utf-8"?>
<!-- iOS 스타일 비밀번호 확인 다이얼로그 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_dialog_rounded"
    android:paddingHorizontal="24dp"
    android:paddingTop="28dp"
    android:paddingBottom="20dp">

    <!-- 아이콘 -->
    <ImageView
        android:id="@+id/iv_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_lock"
        android:tint="@color/md_theme_primary"
        android:contentDescription="잠금" />

    <!-- 제목 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="비밀번호 확인"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_primary" />

    <!-- 설명 -->
    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="게시글 작성 시 입력한 비밀번호를 입력하세요"
        android:textSize="13sp"
        android:textColor="@color/app_text_tertiary"
        android:gravity="center" />

    <!-- 비밀번호 입력 -->
    <EditText
        android:id="@+id/et_password"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="18dp"
        android:hint="비밀번호"
        android:inputType="textPassword"
        android:textSize="14sp"
        android:textColor="@color/app_text_primary"
        android:textColorHint="@color/app_text_hint"
        android:background="@drawable/bg_search_bar"
        android:paddingHorizontal="14dp"
        android:importantForAutofill="no" />

    <!-- 에러 메시지 -->
    <TextView
        android:id="@+id/tv_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textSize="12sp"
        android:textColor="#E55B5B"
        android:visibility="gone" />

    <!-- 버튼 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="18dp">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="취소"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_secondary"
            android:background="@drawable/bg_button_dialog_secondary" />

        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:text="확인"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onPrimary"
            android:background="@drawable/bg_button_dialog_primary" />
    </LinearLayout>

</LinearLayout>
