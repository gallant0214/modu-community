<?xml version="1.0" encoding="utf-8"?>
<!-- iOS 스타일 구인등록 확인 다이얼로그 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_dialog_rounded"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="20dp">

    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_description"
        android:tint="#FF5722"
        android:contentDescription="경고" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="등록 전 확인"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_primary" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="허위 구인 또는 실제 근무조건과 다른 내용 기재 시\n게시글 삭제, 계정 정지 등의 조치가 이루어질 수 있습니다.\n\n공고 내용에 대한 책임은 작성자에게 있습니다."
        android:textSize="13sp"
        android:textColor="@color/app_text_secondary"
        android:lineSpacingMultiplier="1.4"
        android:gravity="center" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp">

        <CheckBox
            android:id="@+id/cb_confirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="위 내용을 확인했으며 동의합니다."
            android:textSize="13sp"
            android:textColor="@color/app_text_primary" />
    </LinearLayout>

    <!-- 버튼 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="취소"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_secondary"
            android:background="@drawable/bg_button_dialog_secondary" />

        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:text="최종 등록하기"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onPrimary"
            android:background="@drawable/bg_button_dialog_primary" />
    </LinearLayout>
</LinearLayout>
