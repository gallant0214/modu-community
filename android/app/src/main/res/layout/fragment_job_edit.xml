<?xml version="1.0" encoding="utf-8"?>
<!-- 구인 게시글 수정 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_surface">

    <!-- 상단 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="뒤로가기"
            app:tint="@color/app_icon_dark" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="구인 수정"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_primary" />

        <TextView
            android:id="@+id/btn_submit"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="수정"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onPrimary"
            android:background="@drawable/bg_login_button"
            android:paddingHorizontal="20dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/app_divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 제목 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="제목"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary" />

            <EditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:textSize="14sp"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <!-- 상세 내용 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="상세 내용"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/et_description"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:textSize="14sp"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:padding="12dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:importantForAutofill="no" />

            <!-- 급여 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="급여"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/et_salary"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:textSize="14sp"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <!-- 연락처 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="연락처"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/et_contact"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:textSize="14sp"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <!-- 모집 인원 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="모집 인원"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/et_headcount"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:textSize="14sp"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <!-- 모집기간 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="모집기간"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/et_deadline"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:textSize="14sp"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <!-- 우대조건 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="우대조건 (선택)"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/et_preferences"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:textSize="14sp"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <!-- 복리후생 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="복리후생 (선택)"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/app_text_tertiary"
                android:layout_marginTop="16dp" />

            <EditText
                android:id="@+id/et_benefits"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_search_bar"
                android:textSize="14sp"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <!-- 로딩 -->
            <ProgressBar
                android:id="@+id/progress_bar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
