<?xml version="1.0" encoding="utf-8"?>
<!-- 지역 변경 바텀시트: 광역시/도 선택 → 구/시/군 선택 2단계 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded">

    <!-- 드래그 핸들 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@color/app_text_hint"
        android:alpha="0.4" />

    <!-- 헤더: 뒤로가기 + 제목 + 닫기 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:layout_marginTop="4dp">

        <ImageButton
            android:id="@+id/btn_back_step"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로"
            android:padding="8dp"
            android:tint="@color/app_icon_tint"
            android:visibility="gone" />

        <!-- btn_back_step gone일 때 왼쪽 여백 유지 -->
        <Space
            android:id="@+id/space_left"
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/tv_step_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="광역시/도 선택"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_primary" />

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="닫기"
            android:padding="8dp"
            android:tint="@color/app_icon_tint" />

    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/app_divider" />

    <!-- 지역 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_region_sheet"
        android:layout_width="match_parent"
        android:layout_height="420dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp" />

</LinearLayout>
