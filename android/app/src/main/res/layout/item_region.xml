<?xml version="1.0" encoding="utf-8"?>
<!-- 지역 선택 리스트: 시/군 아이템 (클릭 가능) -->
<!-- 구조: [도시명 · 게시글 수 .................. N배지] -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/app_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="?attr/selectableItemBackground">

        <!-- 도시명 -->
        <TextView
            android:id="@+id/tv_region_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="구미시"
            android:textSize="15sp"
            android:textColor="@color/app_text_secondary" />

        <!-- 게시글 수 -->
        <TextView
            android:id="@+id/tv_region_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=" · 5개"
            android:textSize="13sp"
            android:textColor="@color/app_text_disabled" />

        <!-- N 배지 (오늘 새 글 있을 때만 표시) -->
        <TextView
            android:id="@+id/tv_badge_new"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="N"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_badge_new"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="16dp"
        android:background="@color/app_divider" />
</LinearLayout>
