<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_dialog_rounded"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="20dp">

    <!-- 아이콘 -->
    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_check"
        android:tint="@color/md_theme_primary"
        android:contentDescription="태그 선택" />

    <!-- 타이틀 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="태그 선택"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_primary" />

    <!-- 설명 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="시험 유형을 선택하세요"
        android:textSize="13sp"
        android:textColor="@color/app_text_tertiary" />

    <!-- iOS 세그먼트 컨트롤 -->
    <LinearLayout
        android:id="@+id/layout_segment"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="18dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_segment_container">

        <TextView
            android:id="@+id/seg_0"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="기타"
            android:textSize="14sp"
            android:textColor="@color/app_text_primary" />

        <!-- 구분선 -->
        <View
            android:id="@+id/divider_0"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/app_divider_strong" />

        <TextView
            android:id="@+id/seg_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="실기"
            android:textSize="14sp"
            android:textColor="@color/app_text_primary" />

        <!-- 구분선 -->
        <View
            android:id="@+id/divider_1"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/app_divider_strong" />

        <TextView
            android:id="@+id/seg_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="구술"
            android:textSize="14sp"
            android:textColor="@color/app_text_primary" />
    </LinearLayout>

    <!-- 취소 버튼 -->
    <TextView
        android:id="@+id/btn_cancel"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text="취소"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_secondary"
        android:background="@drawable/bg_button_dialog_secondary" />
</LinearLayout>
