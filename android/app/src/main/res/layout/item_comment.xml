<?xml version="1.0" encoding="utf-8"?>
<!-- 댓글/대댓글 아이템 -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="10dp"
    android:paddingHorizontal="16dp"
    android:background="@color/app_surface">

    <!-- 헤더: 작성자 (IP)              ··· -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 대댓글 표시 -->
        <TextView
            android:id="@+id/tv_reply_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↳ "
            android:textSize="14sp"
            android:textColor="@color/app_text_disabled"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_author"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_primary" />

        <TextView
            android:id="@+id/tv_ip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/app_text_disabled"
            android:layout_marginStart="4dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 더보기 (삭제) -->
        <ImageView
            android:id="@+id/btn_more"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="더보기"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- 댓글 내용 -->
    <TextView
        android:id="@+id/tv_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/app_text_secondary"
        android:layout_marginTop="4dp"
        android:lineSpacingExtra="2dp" />

    <!-- 하단: 날짜  답글쓰기  신고        ♡ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/app_text_hint" />

        <!-- 답글쓰기 -->
        <TextView
            android:id="@+id/btn_reply"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="답글쓰기"
            android:textSize="12sp"
            android:textColor="@color/app_text_hint"
            android:background="?attr/selectableItemBackground"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp"
            android:layout_marginStart="12dp" />

        <!-- 신고 -->
        <TextView
            android:id="@+id/btn_report"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="신고"
            android:textSize="12sp"
            android:textColor="#E53E3E"
            android:background="?attr/selectableItemBackground"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp"
            android:layout_marginStart="12dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 좋아요 -->
        <TextView
            android:id="@+id/btn_like"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#E53E3E"
            android:background="?attr/selectableItemBackground"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp" />
    </LinearLayout>

    <!-- 구분선 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/app_divider"
        android:layout_marginTop="10dp" />

</LinearLayout>
