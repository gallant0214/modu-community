<?xml version="1.0" encoding="utf-8"?>
<!-- 카테고리 브라우저 (후기 탭 메인) -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_surface"
    tools:context="com.moduji.app.ui.community.CommunityHomeFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 상단 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="10dp">

            <!-- 타이틀 + 알림 아이콘 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="후기 게시판"
                    android:textSize="27sp"
                    android:textStyle="bold"
                    android:textColor="@color/app_text_primary" />

                <ImageButton
                    android:id="@+id/btn_keyword_alert"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_notification"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="키워드 알림 설정"
                    android:scaleType="centerInside"
                    android:padding="6dp"
                    android:tint="@color/app_icon_tint" />
            </LinearLayout>

            <!-- 안내 텍스트 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="시험 카테고리를 선택해 주세요"
                android:textSize="13sp"
                android:textColor="@color/app_text_hint"
                android:layout_marginTop="2dp" />

            <!-- 검색 바 -->
            <EditText
                android:id="@+id/et_search"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_search_bar"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:drawableTint="@color/app_icon_tint_muted"
                android:hint="카테고리 검색 (예: 축구, ㅊㄱ)"
                android:textSize="14sp"
                android:textColor="@color/app_text_secondary"
                android:textColorHint="@color/app_text_hint"
                android:paddingHorizontal="12dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/app_divider" />

        <!-- 스크롤 영역 -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 로딩 표시 -->
                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="40dp"
                    android:visibility="gone" />

                <!-- 에러 표시 -->
                <LinearLayout
                    android:id="@+id/layout_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_error"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/app_text_hint"
                        android:gravity="center" />

                    <TextView
                        android:id="@+id/btn_retry"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="다시 시도"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_login_button"
                        android:paddingHorizontal="20dp"
                        android:layout_marginTop="12dp" />
                </LinearLayout>

                <!-- 인기 카테고리 섹션 -->
                <LinearLayout
                    android:id="@+id/section_popular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥 인기 카테고리"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_text_primary" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_popular"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_community_category" />
                </LinearLayout>

                <!-- 구분선 -->
                <View
                    android:id="@+id/divider_popular"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="@color/app_surface_variant"
                    android:visibility="gone" />

                <!-- 전체 카테고리 섹션 -->
                <LinearLayout
                    android:id="@+id/section_all"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_all_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="전체 카테고리"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_text_primary" />

                    <!-- 종목 더 보기 버튼 -->
                    <TextView
                        android:id="@+id/btn_show_more"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="종목 더 보기 ▼"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_theme_primary"
                        android:background="?attr/selectableItemBackground" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_all"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:nestedScrollingEnabled="false"
                        android:visibility="gone"
                        tools:listitem="@layout/item_community_category" />
                </LinearLayout>

                <!-- 검색 결과 없음 -->
                <TextView
                    android:id="@+id/tv_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="검색 결과가 없습니다"
                    android:textSize="14sp"
                    android:textColor="@color/app_text_hint"
                    android:gravity="center"
                    android:padding="40dp"
                    android:visibility="gone" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>
</FrameLayout>
