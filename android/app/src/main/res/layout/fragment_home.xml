<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg"
    tools:context="com.moduji.app.ui.home.HomeFragment">

    <!-- ================================================ -->
    <!-- 고정 헤더: 타이틀                                   -->
    <!-- ================================================ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="모두의 지도사 커뮤니티"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_primary"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp" />

    <!-- ================================================ -->
    <!-- 검색 바 카드 (고정)                                 -->
    <!-- ================================================ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="1dp"
        app:cardBackgroundColor="@color/app_surface"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                app:tint="@color/app_icon_tint_muted"
                android:contentDescription="검색" />

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="자격증, 후기, 구인 검색"
                android:textSize="14sp"
                android:textColor="@color/app_text_primary"
                android:textColorHint="@color/app_text_hint"
                android:background="@android:color/transparent"
                android:layout_marginStart="8dp"
                android:maxLines="1"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:inputType="text" />

            <ImageView
                android:id="@+id/btn_clear_search"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_close"
                app:tint="@color/app_icon_tint_muted"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="검색 지우기"
                android:visibility="gone" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ================================================ -->
    <!-- 검색 결과 영역 (검색 시에만 표시)                    -->
    <!-- ================================================ -->
    <LinearLayout
        android:id="@+id/layout_search_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/app_bg"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_search_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="검색 결과"
            android:textSize="13sp"
            android:textColor="@color/app_text_hint"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:background="@color/app_surface" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_search_results"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
    </LinearLayout>

    <!-- ================================================ -->
    <!-- 스크롤 영역 (Pull-to-Refresh)                     -->
    <!-- ================================================ -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <!-- ================================================ -->
            <!-- 섹션 1: 인기 종목 (가로 스크롤) 카드                -->
            <!-- ================================================ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/app_surface"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="18dp"
                    android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginBottom="14dp"
                        android:text="인기 종목"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="@color/app_text_primary" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_popular_categories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:paddingHorizontal="16dp"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_popular_category" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================ -->
            <!-- 광고 Placeholder #1                               -->
            <!-- ================================================ -->
            <FrameLayout
                android:id="@+id/ad_container_top"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:background="@color/app_surface"
                android:visibility="gone" />

            <!-- ================================================ -->
            <!-- 섹션 2: 인기 게시글 카드                            -->
            <!-- ================================================ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/app_surface"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="18dp"
                    android:paddingBottom="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="인기 게시글"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/app_text_primary" />

                        <TextView
                            android:id="@+id/btn_more_reviews"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="더보기"
                            android:textSize="13sp"
                            android:textColor="@color/app_text_hint"
                            android:background="?attr/selectableItemBackground"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="4dp"
                            android:drawableEnd="@drawable/ic_arrow_right"
                            android:drawablePadding="0dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="@color/app_divider" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_popular_reviews"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_post_card" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================ -->
            <!-- 섹션 3: 최신 구인 카드                              -->
            <!-- ================================================ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/app_surface"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="18dp"
                    android:paddingBottom="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="최신 구인"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/app_text_primary" />

                        <TextView
                            android:id="@+id/btn_more_jobs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="더보기"
                            android:textSize="13sp"
                            android:textColor="@color/app_text_hint"
                            android:background="?attr/selectableItemBackground"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="4dp"
                            android:drawableEnd="@drawable/ic_arrow_right"
                            android:drawablePadding="0dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="@color/app_divider" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_latest_jobs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_job_card" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================ -->
            <!-- 광고 Placeholder #2                               -->
            <!-- ================================================ -->
            <FrameLayout
                android:id="@+id/ad_container_bottom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="60dp"
                android:background="@color/app_surface"
                android:visibility="gone" />

            <!-- ================================================ -->
            <!-- 섹션 4: 최신 게시글 카드                            -->
            <!-- ================================================ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                app:cardBackgroundColor="@color/app_surface"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="18dp"
                    android:paddingBottom="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="최신 게시글"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/app_text_primary" />

                        <TextView
                            android:id="@+id/btn_more_posts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="더보기"
                            android:textSize="13sp"
                            android:textColor="@color/app_text_hint"
                            android:background="?attr/selectableItemBackground"
                            android:paddingHorizontal="4dp"
                            android:paddingVertical="4dp"
                            android:drawableEnd="@drawable/ic_arrow_right"
                            android:drawablePadding="0dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginHorizontal="16dp"
                        android:background="@color/app_divider" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_latest_posts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_post_card" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
