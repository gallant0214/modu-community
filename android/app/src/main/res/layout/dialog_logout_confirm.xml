<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_dialog_rounded"
    android:paddingHorizontal="24dp"
    android:paddingTop="24dp"
    android:paddingBottom="20dp">

    <!-- 아이콘 -->
    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_logout"
        android:tint="@color/md_theme_primary"
        android:contentDescription="로그아웃" />

    <!-- 타이틀 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="로그아웃"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/app_text_primary" />

    <!-- 설명 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="로그아웃 하시겠습니까?"
        android:textSize="13sp"
        android:textColor="@color/app_text_tertiary"
        android:gravity="center" />

    <!-- 버튼 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <!-- 취소 버튼 -->
        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:gravity="center"
            android:text="취소"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/app_text_secondary"
            android:background="@drawable/bg_button_dialog_secondary" />

        <!-- 로그아웃 버튼 -->
        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:gravity="center"
            android:text="로그아웃"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onPrimary"
            android:background="@drawable/bg_button_dialog_primary" />
    </LinearLayout>
</LinearLayout>
