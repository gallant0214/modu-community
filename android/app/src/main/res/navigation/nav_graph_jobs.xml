<?xml version="1.0" encoding="utf-8"?>
<!-- 구인 탭 내부 서브 네비게이션 -->
<!-- RegionSelectFragment → JobsListFragment 2단계 구조 -->
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_jobs"
    app:startDestination="@id/regionSelectFragment">

    <!-- 1단계: 지역 선택 -->
    <fragment
        android:id="@+id/regionSelectFragment"
        android:name="com.moduji.app.ui.jobs.RegionSelectFragment"
        android:label="지역 선택"
        tools:layout="@layout/fragment_region_select">

        <action
            android:id="@+id/action_regionSelect_to_jobsList"
            app:destination="@id/jobsListFragment" />

        <action
            android:id="@+id/action_regionSelect_to_jobWrite"
            app:destination="@id/jobWriteFragment"
            app:enterAnim="@anim/slide_up_enter"
            app:exitAnim="@anim/no_anim"
            app:popEnterAnim="@anim/no_anim"
            app:popExitAnim="@anim/slide_down_exit" />

        <action
            android:id="@+id/action_regionSelect_to_jobDetail"
            app:destination="@id/jobDetailFragment" />
    </fragment>

    <!-- 2단계: 지역별 구인 리스트 -->
    <fragment
        android:id="@+id/jobsListFragment"
        android:name="com.moduji.app.ui.jobs.JobsListFragment"
        android:label="구인 리스트"
        tools:layout="@layout/fragment_jobs_list">

        <argument
            android:name="regionCode"
            app:argType="string" />
        <argument
            android:name="regionName"
            app:argType="string" />

        <action
            android:id="@+id/action_jobsList_to_jobWrite"
            app:destination="@id/jobWriteFragment"
            app:enterAnim="@anim/slide_up_enter"
            app:exitAnim="@anim/no_anim"
            app:popEnterAnim="@anim/no_anim"
            app:popExitAnim="@anim/slide_down_exit" />

        <action
            android:id="@+id/action_jobsList_to_jobDetail"
            app:destination="@id/jobDetailFragment" />
    </fragment>

    <!-- 구인 게시글 상세 -->
    <fragment
        android:id="@+id/jobDetailFragment"
        android:name="com.moduji.app.ui.jobs.JobDetailFragment"
        android:label="구인 상세"
        tools:layout="@layout/fragment_job_detail">

        <argument
            android:name="postId"
            app:argType="integer" />

        <action
            android:id="@+id/action_jobDetail_to_jobEdit"
            app:destination="@id/jobEditFragment" />
    </fragment>

    <!-- 구인 게시글 수정 -->
    <fragment
        android:id="@+id/jobEditFragment"
        android:name="com.moduji.app.ui.jobs.JobEditFragment"
        android:label="구인 수정"
        tools:layout="@layout/fragment_job_edit">

        <argument
            android:name="postId"
            app:argType="integer" />
    </fragment>

    <!-- 3단계: 구인 글쓰기 -->
    <fragment
        android:id="@+id/jobWriteFragment"
        android:name="com.moduji.app.ui.jobs.JobWriteFragment"
        android:label="구인 글쓰기"
        tools:layout="@layout/fragment_job_write">

        <argument
            android:name="regionCode"
            app:argType="string" />
        <argument
            android:name="regionName"
            app:argType="string" />

        <action
            android:id="@+id/action_jobWrite_to_jobsList"
            app:destination="@id/jobsListFragment"
            app:popUpTo="@id/regionSelectFragment"
            app:popUpToInclusive="false" />
    </fragment>

</navigation>
